{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "willow",
  "name": "Jylhis Docs",
  "colors": {
    "primary": "#b5703c",
    "light": "#d4884a",
    "dark": "#8e5530"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting started",
            "pages": [
