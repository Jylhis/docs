    "global": {
      "anchors": [
        {
          "anchor": "Projects",
          "href": "https://www.jylhis.com/projects/",
          "icon": "folder-open"
        },
        {
          "anchor": "GitHub",
          "href": "https://github.com/Jylhis",
          "icon": "github"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "links": [
      {
        "label": "jylhis.com",
        "href": "https://jylhis.com"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Website",
      "href": "https://www.jylhis.com"
    }
  },
  "background": {
    "color": {
      "light": "#faf7f2",
      "dark": "#1a1714"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude",
      "perplexity",
      "mcp",
      "cursor",
      "vscode"
    ]
  },
  "description": "From me, for me",
  "appearance": {
    "default": "system"
  },
  "css": "/custom.css",
  "styling": {
    "eyebrows": "breadcrumbs",
    "latex": true,
    "codeblocks": {
      "themes": {
        "light": "everforest-light",
        "dark": "everforest-dark"
      }
    }
  },
  "api": {
    "playground": {
      "display": "interactive"
    }
  },
  "metadata": {
    "timestamp": true
  },
  "seo": {
    "indexing": "navigable"
  },
  "interaction": {
    "drilldown": true
  },
  "footer": {
    "socials": {
      "github": "https://github.com/Jylhis",
      "linkedin": "https://www.linkedin.com/in/jylhis"
    }
  }
}