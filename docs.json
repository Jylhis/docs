              "essentials/reusable-snippets"
            ]
          },
          {
            "group": "AI tools",
            "pages": [
              "ai-tools/cursor",
              "ai-tools/claude-code",
              "ai-tools/windsurf"
            ]
          }
        ]
      },
      {
        "tab": "Knowledge",
        "groups": [
          {
            "group": "Linux",
            "pages": [
              "knowledge/linux-toolbox"
            ]
          }
        ]
      },
      {
